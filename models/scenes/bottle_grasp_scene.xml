<!-- Phase 1: desk + upright thin bottle + Shadow Hand (mocap-driven) -->
<mujoco model="bottle_grasp_scene">
  <include file="../../models/shadow_hand/right_hand_free.xml"/>
  <include file="../../third_party/mujoco_menagerie/shadow_hand/keyframes.xml"/>

  <compiler angle="radian" meshdir="../../third_party/mujoco_menagerie/shadow_hand/assets" autolimits="true"/>

  <option timestep="0.001" integrator="implicitfast" cone="elliptic" impratio="10"/>

  <statistic center="0.5 0 0.9" extent="0.6"/>

  <visual>
    <headlight diffuse="0.6 0.6 0.6" ambient="0.3 0.3 0.3" specular="0 0 0"/>
    <rgba haze="0.15 0.25 0.35 1"/>
    <global azimuth="140" elevation="-25" offwidth="1920" offheight="1080"/>
    <quality shadowsize="4096"/>
  </visual>

  <asset>
    <texture type="skybox" builtin="gradient" rgb1="0.3 0.5 0.7" rgb2="0 0 0" width="512" height="3072"/>
    <texture type="2d" name="groundplane" builtin="checker" mark="edge" rgb1="0.2 0.3 0.4" rgb2="0.1 0.2 0.3"
      markrgb="0.8 0.8 0.8" width="300" height="300"/>
    <texture type="2d" name="wood" builtin="flat" rgb1="0.55 0.38 0.22" width="1" height="1"/>
    <material name="groundplane" texture="groundplane" texuniform="true" texrepeat="5 5" reflectance="0.1"/>
    <material name="desk_mat" texture="wood" rgba="0.55 0.38 0.22 1"/>
    <material name="bottle_mat" rgba="0.15 0.55 0.85 0.95" specular="0.4" shininess="0.3"/>
  </asset>

  <worldbody>
    <light pos="0.5 0 2.0" dir="0 0 -1" directional="true" castshadow="true"/>
    <light pos="0.2 0.5 1.5" dir="0.2 -0.3 -1" directional="true"/>
    <geom name="floor" type="plane" size="0 0 0.05" material="groundplane"/>

    <!-- Desk: top surface at z = 0.75 m -->
    <body name="desk" pos="0.55 0 0.725">
      <geom name="desk_top" type="box" size="0.45 0.35 0.025" material="desk_mat" friction="0.8 0.005 0.0001"/>
    </body>

    <!-- Thin bottle: radius 22 mm, height 280 mm, standing upright on desk -->
    <!-- Center z = 0.75 + 0.14 = 0.89 m -->
    <body name="bottle" pos="0.55 0 0.89">
      <freejoint name="bottle_free"/>
      <inertial pos="0 0 0" mass="0.15" diaginertia="0.00015 0.00015 0.00002"/>
      <geom name="bottle_geom" type="cylinder" size="0.022 0.14" material="bottle_mat"
            friction="1.2 0.01 0.001" condim="4" solimp="0.9 0.95 0.001" solref="0.005 1"/>
    </body>

    <!-- Reference target marker -->
    <body mocap="true" name="hand_target" pos="0.58 -0.04 0.87" quat="0.707107 0 0.707107 0"/>
  </worldbody>
</mujoco>
